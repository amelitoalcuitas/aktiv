FROM node:20-alpine

WORKDIR /app

# Copy package files first for better layer caching
COPY package*.json ./

RUN npm ci --production=false

# Copy the rest of the app
COPY . .

# Build arg declarations â€” these get baked in at build time
ARG NUXT_PUBLIC_API_BASE=/api \
    NUXT_PUBLIC_REVERB_KEY \
    NUXT_PUBLIC_REVERB_HOST \
    NUXT_PUBLIC_REVERB_PORT \
    NUXT_PUBLIC_REVERB_SCHEME \
    NUXT_PUBLIC_GOOGLE_MAPS_KEY \
    NUXT_CLARITY_ID \
    NUXT_API_BASE_INTERNAL

ENV NUXT_PUBLIC_API_BASE=$NUXT_PUBLIC_API_BASE \
    NUXT_PUBLIC_REVERB_KEY=$NUXT_PUBLIC_REVERB_KEY \
    NUXT_PUBLIC_REVERB_HOST=$NUXT_PUBLIC_REVERB_HOST \
    NUXT_PUBLIC_REVERB_PORT=$NUXT_PUBLIC_REVERB_PORT \
    NUXT_PUBLIC_REVERB_SCHEME=$NUXT_PUBLIC_REVERB_SCHEME \
    NUXT_PUBLIC_GOOGLE_MAPS_KEY=$NUXT_PUBLIC_GOOGLE_MAPS_KEY \
    NUXT_CLARITY_ID=$NUXT_CLARITY_ID \
    NUXT_API_BASE_INTERNAL=$NUXT_API_BASE_INTERNAL

RUN npm run build

EXPOSE 3000

ENV HOST=0.0.0.0 \
    PORT=3000

CMD ["node", ".output/server/index.mjs"]